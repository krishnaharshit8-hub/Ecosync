# ── FastAPI ─────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
DATABASE_URL=postgresql://ecosync_user:your_password@localhost:5432/ecosync_db
BACKEND_PORT=8000

# ── Blockchain ─────────────────────────────────────────────
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
PRIVATE_KEY=your-metamask-wallet-private-key-no-0x-prefix
CONTRACT_ADDRESS=deployed-energytrade-contract-address
TOKEN_CONTRACT_ADDRESS=deployed-energytoken-contract-address

# ── MQTT ───────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=ecosync/houses/#

# ── NVIDIA Isaac Sim ───────────────────────────────────────
ISAAC_SIM_PATH=/home/user/.local/share/ov/pkg/isaac_sim-2023.1.1

# ── JWT Auth ───────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── AES Encryption ─────────────────────────────────────────
AES_KEY=generate-with-python-os.urandom(32).hex()
